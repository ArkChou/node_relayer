# Relayer 私钥
PRIVATE_KEY=your_private_key_here

# RPC URL 列表（逗号分隔，支持多个 RPC 自动切换）
RPC_URLS=https://rpc.ankr.com/base_sepolia/YOUR_API_KEY,https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY,https://sepolia.base.org

# 链 ID
CHAIN_ID=84532

# Redis Cluster 节点（逗号分隔）
REDIS_CLUSTER_NODES=redis-1:6379,redis-2:6379,redis-3:6379

# Relayer 地址
RELAYER_ADDRESS=0xYourRelayerAddress

# Redis 密码（强烈推荐设置！）
REDIS_PASSWORD=Whiseper!!*
